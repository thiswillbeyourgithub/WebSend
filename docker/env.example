# WebSend Environment Configuration
# Copy this file to .env and adjust values.

# ============ Build Options ============
# Run npm audit during docker build to catch known vulnerabilities.
# Disabled by default: the advisory database changes independently of your
# code, making builds non-deterministic (a passing build today may fail
# tomorrow). Enable if you want vulnerability gating at build time.
# RUN_NPM_AUDIT=false

# Domain or IP address where the server is accessible
# Used as default for TURN_SERVER if not explicitly set.
# Examples:
#   DOMAIN=192.168.1.50      (local network IP)
#   DOMAIN=myserver.com      (public domain)
#   DOMAIN=localhost         (local testing only, won't work across devices)
DOMAIN=192.168.1.50

# Allowed origins for API requests (CSRF/origin validation).
# Comma-separated list of full origins (protocol + domain).
# If not set, defaults to https://{DOMAIN} and http://{DOMAIN}.
# Set this if your app is accessed via multiple domains or subdomains.
# Examples:
#   ALLOWED_ORIGINS=https://share.hospital.org
#   ALLOWED_ORIGINS=https://share.hospital.org,https://backup.hospital.org
#   ALLOWED_ORIGINS=https://192.168.1.50,http://192.168.1.50
# ALLOWED_ORIGINS=

# DEV mode: enables verbose debug logging for handshake/connection troubleshooting
# Set to 1 to enable, 0 to disable (default)
DEV=0

# ============ ICE Server Configuration ============
# WebRTC needs ICE servers to establish peer-to-peer connections.
#
# STUN (Session Traversal Utilities for NAT):
#   - Lightweight: helps peers discover their public IP:port
#   - Data still flows directly peer-to-peer after discovery
#   - Works in ~80% of NAT scenarios
#   - Google provides free public STUN servers
#
# TURN (Traversal Using Relays around NAT):
#   - Heavy: DEFAULT data is relayed through the TURN server
#   - Required when direct P2P is impossible (symmetric NAT, strict firewalls)
#   - Should be self-hosted for privacy (sees encrypted traffic)
#   - Uses time-based credentials for security

# Optional: Your own STUN server (host:port)
# If set, this STUN server is used for NAT discovery.
# Leave empty to rely on Google's STUN or TURN only.
# Example: STUN_SERVER=stun.yourdomain.com:3478
# STUN_SERVER=

# Allow Google's public STUN server as a fallback?
# If true and STUN_SERVER is set, Google's STUN is added as secondary.
# If true and STUN_SERVER is empty, Google's STUN is the only STUN server.
# If false, no Google servers are used (fully self-hosted).
# Default: true
STUN_GOOGLE_FALLBACK=true

# Optional: External IP for the coturn container (must be an IP, not a hostname).
# Only needed if DOMAIN is a hostname — coturn's --external-ip does not resolve DNS.
# Defaults to DOMAIN if not set (works when DOMAIN is already an IP).
# Example: TURN_EXTERNAL_IP=1.2.3.4
# TURN_EXTERNAL_IP=

# Optional: Your TURN relay server (host:port)
# Required when peers are behind symmetric NAT or strict firewalls.
# The server generates time-based credentials using TURN_SECRET.
# Example: TURN_SERVER=turn.yourdomain.com:3478
# Example: TURN_SERVER=192.168.1.50:3478 (if reusing existing coturn on different port)
# TURN_SERVER=

# Shared secret for TURN time-based credentials (required if TURN_SERVER is set)
# Must match the secret configured in your coturn server (--use-auth-secret --static-auth-secret=XXX)
# Generate with: openssl rand -hex 32
# TURN_SECRET=

# How long TURN credentials remain valid, in seconds.
# Default: 3600  (1 hour). Shorter = more secure, but less convenient.
# TURN_CREDENTIAL_TTL=3600

# ============ TURNS (TURN-over-TLS) — Optional ============
# TURNS wraps TURN traffic in TLS, making it look like HTTPS on port 443 or 8443.
# Useful for corporate networks that block non-standard ports or inspect UDP traffic.
#
# To enable TURNS:
# 1. Set TURNS_PORT here (the port coturn listens on for TLS, e.g. 8443)
# 2. Configure coturn with TLS: remove --no-tls, add --tls-listening-port,
#    --cert, and --pkey flags pointing to your TLS certificate files.
#    See docker-compose.yml coturn section comments for details.
# TURNS_PORT=8443

# ============ Debug: Force Connection Method ============
# Force WebRTC to use a specific transport for debugging.
# Useful to verify each connection path works independently before troubleshooting.
# Requires DEV=1 to see detailed logs (but filtering works regardless).
#
# Values:
#   DEFAULT         — (default) normal behavior, all configured servers
#   DIRECT      — no ICE servers, LAN host candidates only (same subnet)
#   STUN        — self-hosted STUN only (no Google, no TURN)
#   GOOGLE_STUN — Google's public STUN only
#   TURN        — TURN UDP+TCP relay only (forces relay transport policy)
#   TURNS       — TURN-over-TLS only (forces relay transport policy)
#
# Example workflow: start with DIRECT, then GOOGLE_STUN, then TURN, then TURNS
# to isolate which layer is broken.
#
# Caveat — TURN / TURNS modes between two peers sharing the same coturn:
#   When both peers are forced to relay-only AND both go through the same
#   TURN server, both peers' relay candidates carry the same external IP
#   (the coturn server's). Chrome's ICE engine prunes candidate pairs whose
#   local and remote IPs match, so no pair is created, no connectivity check
#   is sent, and the connection fails in milliseconds with "Remote candidates
#   received: NONE". This is not a coturn / firewall / hairpin problem — the
#   server allocates correctly and the candidates appear inline in the SDP;
#   they are filtered on the receiving Chrome side.
#   In real production this rarely bites because at least one peer has a
#   host/srflx candidate that succeeds first. To actually validate the
#   relay path end-to-end you need the two peers to land on different
#   relay IPs, e.g. dual-stack coturn (advertise both IPv4 and IPv6
#   --external-ip) or a second coturn instance bound to a different IP.
#   Single-peer reachability of TURN/TURNS is still validated by the
#   client-side diagnoseIceServers() probe regardless.
# DEV_FORCE_CONNECTION=DEFAULT

# ============ OCR (scribe.js) — Optional ============
# Settings for the searchable PDF export feature (OCR via scribe.js).
# OEM (OCR engine mode) is always "combined" (Legacy + LSTM) for best accuracy.

# Comma-separated Tesseract language codes for OCR recognition.
# Common codes: eng, fra, deu, spa, ita, por, nld, chi_sim, jpn, kor, rus, ara
# Full list: https://tesseract-ocr.github.io/tessdoc/Data-Files-in-different-versions.html
# Default: eng,fra
# OCR_LANGS=eng,fra

# Tesseract page segmentation mode (PSM). Controls how the OCR engine
# analyzes page layout before recognizing text.
# Common values:
#   3  = Fully automatic page segmentation (no OSD)
#   6  = Assume a single uniform block of text
#   7  = Treat the image as a single text line
#   11 = Sparse text — find as much text as possible, no particular order
#   12 = Sparse text with OSD (orientation and script detection) (default)
#   13 = Raw line, treat as a single text line (no Tesseract hacks)
# Default: 12
# OCR_PSM=12

# ============ Allowed File Types ============
# Controls which file types the sender can upload.
# ONLY_IMAGES = only image/* files
# IMAGE_OR_PDF = image/* plus application/pdf
# ANY = any file type (default)
# ALLOWED_FILE_TYPES=ANY

# ============ SSO (Keycloak via oauth2-proxy) — Experimental ============
# Gate WebSend behind Keycloak authentication using oauth2-proxy.
# This is a simple "authenticated or not" gate — no user/group mapping.
# To enable, uncomment the oauth2-proxy service in docker-compose.yml
# and configure the variables below.
#
# IMPORTANT: When using oauth2-proxy, point your reverse proxy (Caddy)
# at port 4180 (oauth2-proxy) instead of 7395 (websend), and remove
# the websend port mapping in docker-compose.yml.

# Keycloak OIDC issuer URL (your realm's base URL)
# Example: OAUTH2_OIDC_ISSUER_URL=https://keycloak.example.org/realms/myrealm
# OAUTH2_OIDC_ISSUER_URL=

# Client ID configured in Keycloak for WebSend
# OAUTH2_CLIENT_ID=websend

# Client secret from Keycloak (Credentials tab of the client)
# OAUTH2_CLIENT_SECRET=

# Cookie secret for oauth2-proxy session encryption (must be exactly 32 bytes)
# Generate with: openssl rand -base64 32 | head -c 32
# OAUTH2_COOKIE_SECRET=

# ============ Analytics (Umami) — Optional ============
# Privacy-preserving analytics via Umami (https://umami.is/).
# Umami is a lightweight, open-source, privacy-focused analytics tool that
# does not use cookies and complies with GDPR/CCPA out of the box.
# Analytics are only enabled when both UMAMI_URL and UMAMI_WEBSITE_ID are set.
#
# Note: HTML files are read once at server startup, the analytics snippet
# is injected, and the patched HTML is cached in memory. If you change a
# tracked HTML file (index.html / send.html / receive.html) you must
# restart the server to see the change. Server boot also validates these
# values strictly: invalid characters in UMAMI_URL or UMAMI_WEBSITE_ID
# will cause a fatal startup error.

# Base URL of your Umami instance (without trailing slash)
# Example: UMAMI_URL=https://analytics.example.org
# UMAMI_URL=

# Website ID from your Umami dashboard (UUID format)
# Example: UMAMI_WEBSITE_ID=43f35468-5866-486f-b338-5c615518bf13
# UMAMI_WEBSITE_ID=

# Whether to respect the browser's Do Not Track (DNT) setting.
# "true" = users with DNT enabled will not be tracked (default)
# "false" = track all visitors regardless of DNT setting
# UMAMI_DNT=true
